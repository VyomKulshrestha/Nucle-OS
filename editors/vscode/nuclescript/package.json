{
  "name": "nuclescript",
  "displayName": "NucleScript",
  "description": "Syntax highlighting and language server support for NucleScript (.nsl), the declarative DNA-storage operations language for NucleOS.",
  "version": "0.1.0",
  "publisher": "nuclescript",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/VyomKulshrestha/Nucle-OS.git",
    "directory": "editors/vscode/nuclescript"
  },
  "bugs": {
    "url": "https://github.com/VyomKulshrestha/Nucle-OS/issues"
  },
  "homepage": "https://github.com/VyomKulshrestha/Nucle-OS/tree/main/editors/vscode/nuclescript",
  "keywords": ["nuclescript", "dna", "dna-storage", "language-server", "nucleos"],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:nuclescript"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nuclescript",
        "aliases": ["NucleScript", "nuclescript"],
        "extensions": [".nsl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nuclescript",
        "scopeName": "source.nuclescript",
        "path": "./syntaxes/nuclescript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "NucleScript",
      "properties": {
        "nuclescript.serverPath": {
          "type": "string",
          "default": "nucle-lsp",
          "description": "Path to the nucle-lsp binary. Defaults to looking it up on PATH first (e.g. a local `cargo build` for development); if not found there, a prebuilt binary for your platform is downloaded once from GitHub Releases and cached. Set an absolute path to override both."
        },
        "nuclescript.cliPath": {
          "type": "string",
          "default": "nucle-cli",
          "description": "Path to the nucle-cli binary, used for `Format Document`/format-on-save (`nucle fmt`). Defaults to looking it up on PATH (e.g. a local `cargo build -p nucle_cli`). Set an absolute path if it isn't on PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.0",
    "vscode-tmgrammar-test": "^0.1.3"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "vscode-tmgrammar-snap -s source.nuclescript -g syntaxes/nuclescript.tmLanguage.json ../../../docs/examples/*.nsl"
  }
}
